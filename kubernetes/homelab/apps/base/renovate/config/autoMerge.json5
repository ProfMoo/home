{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": [
        "Auto-merge container updates for trusted containers (patch, minor, and digest)"
      ],
      "matchDatasources": [
        "docker"
      ],
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": true,
      "matchUpdateTypes": [
        "patch",
        "minor",
        "digest"
      ],
      "matchPackagePatterns": [
        "ghcr.io/bjw-s",
        "ghcr.io/home-operations",
        "ghcr.io/esanchezm",
        "ghcr.io/music-assistant/",
        "postfinance/",
        "ghcr.io/gethomepage/",
        "ghcr.io/unpoller/unpoller",
        "ghcr.io/kashalls/kromgo",
        "ghcr.io/twin/gatus",
        "ghcr.io/zwave-js/zwave-js-ui",
        "ghcr.io/coder/code-server",
        "ghcr.io/dictionarry-hub/profilarr",
        "ghcr.io/valkey-io",
        "mirror.gcr.io/envoyproxy/envoy"
      ]
    },
    {
      // GHCR does not expose release timestamps to Renovate's Docker datasource, so
      // minimumReleaseAge cannot reliably wait 28 days per qBittorrent image tag.
      // Renovate debug logs show no currentVersionTimestamp for this package.
      // See https://github.com/renovatebot/renovate/discussions/38143
      // This is a problem for many private trackers, which have a wait period for new version of qBittorrent.
      // An immediate deploy of a new version would break qBittorrent until the new version is added to the whitelist in the private tracker.
      "description": "Do not auto-merge qBittorrent image updates",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/home-operations/qbittorrent"
      ],
      "automerge": false
    },
    {
      "description": "Auto merge helm updates for patch and minor versions (excluding app-template)",
      "matchDatasources": [
        "helm"
      ],
      "excludePackageNames": [
        "app-template"
      ],
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": true,
      "requiredStatusChecks": null,
      "matchUpdateTypes": [
        "patch",
        "minor"
      ]
    },
    {
      "description": "Auto merge app-template updates immediately",
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "app-template"
      ],
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": true,
      "requiredStatusChecks": null,
      "matchUpdateTypes": [
        "patch",
        "minor"
      ]
    },
    {
      "description": [
        "Auto-merge GitHub Actions for patch and minor versions"
      ],
      "matchManagers": [
        "github-actions"
      ],
      "matchDatasources": [
        "github-tags"
      ],
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": true,
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    },
    {
      "description": "Auto-merge raw Kubernetes deployment updates for trusted images",
      "matchManagers": [
        "kubernetes"
      ],
      "matchDatasources": [
        "docker"
      ],
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": true,
      "requiredStatusChecks": null,
      "matchUpdateTypes": [
        "patch",
        "minor",
        "digest"
      ],
      "matchPackagePatterns": [
        "ghcr.io/gethomepage/",
        "postfinance/"
      ]
    },
    {
      "description": "Rook/Ceph versions require 14 days before auto-merge",
      "prBodyNotes": [
        "⏳ **Delayed Automerge**: This Rook/Ceph update will auto-merge after 14 days to allow for soak time",
        "📅 **Merge Date**: {{#if mergeDate}}{{mergeDate}}{{else}}14 days from PR creation{{/if}}"
      ],
      "matchManagers": [
        "flux"
      ],
      "matchPackagePatterns": [
        "^ghcr\\.io/rook/rook-ceph$",
        "^ghcr\\.io/rook/rook-ceph-cluster$"
      ],
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": true,
      "requiredStatusChecks": null,
      "minimumReleaseAge": "14 days",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    },
    {
      "description": "Auto-merge Flux HelmRelease chart updates for patch and minor versions",
      "matchManagers": [
        "flux"
      ],
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": true,
      "requiredStatusChecks": null,
      "matchUpdateTypes": [
        "patch",
        "minor"
      ]
    },
    {
      "description": "Auto-merge Helmfile chart updates for patch and minor versions",
      "matchManagers": [
        "helmfile"
      ],
      "automerge": true,
      "automergeType": "pr",
      "ignoreTests": true,
      "requiredStatusChecks": null,
      "matchUpdateTypes": [
        "patch",
        "minor"
      ]
    }
  ]
}
